<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:id="@+id/rlVideoPlayBack" android:background="@color/white">
    <VideoView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/videoPlayVideo"
            android:layout_alignParentTop="true"
            android:layout_alignParentLeft="true"
            android:layout_alignParentBottom="true"
            android:layout_alignParentRight="true"/>
    <ImageView
            android:layout_width="144px"
            android:layout_height="144px"
            android:id="@+id/imgPlayVideoMenu"
            android:scaleType="fitCenter" android:src="@drawable/ic_launcher"
            android:layout_alignParentBottom="true" android:layout_alignParentRight="true" android:visibility="gone"/>
</RelativeLayout>

